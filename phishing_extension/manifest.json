{
  "manifest_version": 3,
  "name": "AI Phishing Email Detector",
  "version": "1.0",
  "description": "Detect AI & human phishing emails in Gmail",

  "permissions": ["activeTab", "scripting"],

  "host_permissions": [
    "https://mail.google.com/*",
    "http://127.0.0.1:8000/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}
